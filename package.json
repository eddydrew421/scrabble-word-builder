{
  "name": "scrabble-word-builder",
  "version": "1.0.0",
  "description": "Scrabbler word builder for Hasbro Pulse",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "tsx watch src/http/server.ts",
    "start": "node dist/http/server.js",
    "build": "tsc -p tsconfig.json",
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.test.json",
    "verify": "bash scripts/verify.sh"
  },
  "keywords": [
    "scrabble",
    "word-builder",
    "hasbro",
    "pulse"
  ],
  "author": "Edward Drew",
  "license": "ISC",
  "dependencies": {
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.4.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.1",
    "eslint": "^10.7.0",
    "prettier": "^3.9.6",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
